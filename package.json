  "maintainers": [
    {
      "name": "Daniel Jancar"
    }
  ],
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@10.9.4",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build && npm run postbuild",
