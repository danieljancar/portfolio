    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.7",
    "@ng-icons/bootstrap-icons": "^33.2.3",
    "@ng-icons/core": "^33.2.3",
    "@ng-icons/simple-icons": "^33.2.3",
    "date-fns": "^4.4.0",
    "gsap": "^3.15.0",
    "marked": "^18.0.4",
    "ngx-markdown": "^21.3.0",
